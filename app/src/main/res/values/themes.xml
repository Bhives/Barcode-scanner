<resources>

    <style name="Theme.Rplink" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:textColor">@android:color/black</item>
    </style>

    <style name="TextAppearance" parent="TextAppearance.AppCompat" />

    <style name="TextAppearance.GolosRegular">
        <item name="android:fontFamily">@font/golos_regular</item>
    </style>

    <style name="TextAppearance.GolosRegular.12">
        <item name="android:textSize">@dimen/text_12</item>
    </style>

    <style name="TextAppearance.GolosRegular.14">
        <item name="android:textSize">@dimen/text_14</item>
    </style>

    <style name="TextAppearance.GolosRegular.14.White">
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="TextAppearance.GolosRegular.16">
        <item name="android:textSize">@dimen/text_16</item>
    </style>

    <style name="TextAppearance.GolosMedium">
        <item name="android:fontFamily">@font/golos_medium</item>
    </style>

    <style name="TextAppearance.GolosMedium.14">
        <item name="android:textSize">@dimen/text_14</item>
    </style>

    <style name="TextAppearance.GolosMedium.16">
        <item name="android:textSize">@dimen/text_16</item>
    </style>

    <style name="TextAppearance.GolosMedium.16.White">
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="TextAppearance.GolosMedium.24">
        <item name="android:textSize">@dimen/text_24</item>
    </style>

    <style name="TextAppearance.GolosMedium.32">
        <item name="android:textSize">@dimen/text_32</item>
    </style>

    <style name="StatusTextStyle">
        <item name="android:background">@drawable/scan_status_shape</item>
        <item name="android:paddingHorizontal">8dp</item>
        <item name="android:paddingVertical">4dp</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="InputLayoutStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@android:color/white</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="errorEnabled">true</item>
        <item name="hintTextAppearance">@style/TextAppearance.GolosRegular.12</item>
        <item name="hintTextColor">@android:color/black</item>
        <item name="boxStrokeColor">@android:color/black</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
        <item name="errorIconDrawable">@null</item>
    </style>

    <style name="ButtonOutlinedStyle">
        <item name="backgroundTint">@android:color/white</item>
        <item name="android:paddingVertical">@dimen/size_12</item>
        <item name="android:textAppearance">@style/TextAppearance.GolosMedium.16</item>
        <item name="android:textColor">@color/red</item>
        <item name="cornerRadius">48dp</item>
        <item name="strokeColor">@color/red</item>
        <item name="strokeWidth">1dp</item>
    </style>
</resources>